    "version": "0.2.0",
    "configurations": [
        {
            "type": "node-terminal",
            "request": "launch",
            "name": "Open index.html",
            "command": "& \"C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe\" --new-window --user-data-dir=\"${workspaceFolder}\\.vscode\\edge-run-profile\" \"${workspaceFolder}\\index.html\""
        },
        {
            "type": "pwa-msedge",
            "request": "launch",
            "name": "Debug index.html in Edge",
            "runtimeExecutable": "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe",
            "file": "${workspaceFolder}/index.html",
            "userDataDir": "${workspaceFolder}/.vscode/edge-debug-profile"
        }
    ]
}
